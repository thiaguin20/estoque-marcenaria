@model IEnumerable<Estoque.Models.Usuario>

@{
    ViewBag.Title = "Usuarios";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Usuarios - Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d0d0d;
            --bg2: #141414;
            --bg3: #1c1c1c;
            --line: rgba(255,255,255,.08);
            --line2: rgba(255,255,255,.14);
            --txt: #f0ede8;
            --txt2: #9a9690;
            --txt3: #5c5a57;
            --gold: #c9a84c;
            --green: #4ade80;
            --red: #f87171;
        }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
        }

        .shell {
            display: grid;
            grid-template-columns: 220px 1fr;
            min-height: 100vh;
        }

        .sidebar {
            background: var(--bg2);
            border-right: 1px solid var(--line);
            padding: 28px 20px;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        .brand-icon {
            width: 34px;
            height: 34px;
            background: var(--gold);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0d0d0d;
        }

        .brand-name {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
        }

        .brand-sub {
            font-size: 10px;
            color: var(--txt3);
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--txt3);
            padding: 0 8px;
            margin-bottom: 4px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 9px;
            font-size: 13px;
            color: var(--txt2);
            text-decoration: none;
            margin-bottom: 4px;
        }

        .nav-item:hover {
            background: var(--bg3);
            color: var(--txt);
        }

        .nav-item.active {
            background: rgba(201,168,76,.12);
            color: var(--gold);
            border: 1px solid rgba(201,168,76,.22);
        }

        .sidebar-foot {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid var(--line);
        }

        .settings-menu summary {
            list-style: none;
        }

            .settings-menu summary::-webkit-details-marker {
                display: none;
            }

        .settings-panel {
            margin-top: 6px;
        }

        .main {
            padding: 32px;
        }

        .top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 28px;
        }

        .eyebrow {
            color: var(--gold);
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-size: 32px;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            height: 38px;
            padding: 0 14px;
            background: var(--bg3);
            border: 1px solid var(--line2);
            border-radius: 9px;
            color: var(--txt2);
            text-decoration: none;
            font-size: 13px;
        }

        .msg {
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 18px;
            font-size: 13px;
        }

        .msg.error {
            color: var(--red);
            background: rgba(248,113,113,.1);
            border: 1px solid rgba(248,113,113,.25);
        }

        .msg.success {
            color: var(--green);
            background: rgba(74,222,128,.1);
            border: 1px solid rgba(74,222,128,.25);
        }

        .card {
            background: var(--bg2);
            border: 1px solid var(--line);
            border-radius: 14px;
            overflow: hidden;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: var(--bg3);
            color: var(--txt3);
            font-size: 10px;
            letter-spacing: .1em;
            text-transform: uppercase;
            text-align: left;
            padding: 12px 14px;
        }

        td {
            border-top: 1px solid var(--line);
            padding: 14px;
            color: var(--txt2);
            vertical-align: middle;
        }

        .name {
            color: var(--txt);
            font-weight: 600;
        }

        .badge {
            display: inline-flex;
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 12px;
            font-weight: 700;
        }

        .badge.ok {
            color: var(--green);
            background: rgba(74,222,128,.1);
        }

        .badge.wait {
            color: var(--red);
            background: rgba(248,113,113,.1);
        }

        .action {
            border: none;
            border-radius: 8px;
            padding: 9px 12px;
            color: #0d0d0d;
            background: var(--gold);
            font-weight: 700;
            cursor: pointer;
        }

        @@media (max-width: 900px) {
            .shell {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }

            .main {
                padding: 22px 16px;
            }
        }
    </style>
</head>
<body>
    <div class="shell">
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestao</div>
                </div>
            </div>

            <div class="nav-label">Principal</div>
            <a href="@Url.Action("Index", "Produto")" class="nav-item">
                <i class="bi bi-boxes"></i> Estoque
            </a>
            <a href="@Url.Action("Index", "Usuarios")" class="nav-item active">
                <i class="bi bi-people"></i> Usuarios
            </a>
            <div class="sidebar-foot">
                <details class="settings-menu">
                    <summary class="nav-item" style="font-size:12px; cursor:pointer;">
                        <i class="bi bi-gear"></i> Configurações
                    </summary>
                    <div class="settings-panel">
                        <a href="@Url.Action("Logout", "Admin")" class="nav-item" style="font-size:12px;">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </details>
            </div>
        </aside>

        <main class="main">
            <div class="top">
                <div>
                    <div class="eyebrow">Controle de acesso</div>
                    <h1>Usuarios cadastrados</h1>
                </div>
                <a href="@Url.Action("Index", "Produto")" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Voltar ao estoque
                </a>
            </div>

            @if (TempData["Erro"] != null)
            {
                <div class="msg error">@TempData["Erro"]</div>
            }

            @if (TempData["Sucesso"] != null)
            {
                <div class="msg success">@TempData["Sucesso"]</div>
            }

            <div class="card">
                <div style="overflow-x:auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>Usuario</th>
                                <th>E-mail</th>
                                <th>Status</th>
                                <th>Acao</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" style="text-align:center; padding:40px;">
                                        Nenhum usuario cadastrado ainda.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var usuario in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="name">@usuario.Nome</span><br />
                                            <small>@usuario.DataCadastro.ToString("dd/MM/yyyy HH:mm")</small>
                                        </td>
                                        <td>@usuario.Email</td>
                                        <td>
                                            @if (usuario.PodeAcessarAdmin)
                                            {
                                                <span class="badge ok">Liberado</span>
                                            }
                                            else
                                            {
                                                <span class="badge wait">Aguardando</span>
                                            }
                                        </td>
                                        <td>
                                            @using (Html.BeginForm("AlternarPermissao", "Usuarios", new { id = usuario.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="action">
                                                    @(usuario.PodeAcessarAdmin ? "Bloquear" : "Liberar")
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
