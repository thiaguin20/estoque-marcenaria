@model IEnumerable<Estoque.Models.Produto>

@{
    ViewBag.Title = "Estoque";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Estoque — Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d0d0d;
            --bg2: #141414;
            --bg3: #1c1c1c;
            --bg4: #242424;
            --line: rgba(255,255,255,.07);
            --line2: rgba(255,255,255,.12);
            --txt: #f0ede8;
            --txt2: #9a9690;
            --txt3: #5c5a57;
            --gold: #c9a84c;
            --gold-lt: rgba(201,168,76,.12);
            --gold-glow: rgba(201,168,76,.25);
            --green: #4ade80;
            --green-lt: rgba(74,222,128,.1);
            --amber: #fbbf24;
            --amber-lt: rgba(251,191,36,.1);
            --red: #f87171;
            --red-lt: rgba(248,113,113,.1);
            --r: 10px;
            --r-lg: 16px;
        }

        html, body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Inter', system-ui, sans-serif;
            font-size: 14px;
            line-height: 1.5;
            min-height: 100vh;
        }

        .shell {
            display: grid;
            grid-template-columns: 220px 1fr;
            min-height: 100vh;
        }

        /* SIDEBAR */
        .sidebar {
            background: var(--bg2);
            border-right: 1px solid var(--line);
            padding: 28px 20px;
            display: flex;
            flex-direction: column;
            gap: 28px;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-icon {
            width: 34px;
            height: 34px;
            background: var(--gold);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0d0d0d;
            font-size: 15px;
            flex-shrink: 0;
        }

        .brand-name {
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--txt);
        }

        .brand-sub {
            font-size: 10px;
            color: var(--txt3);
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--txt3);
            padding: 0 8px;
            margin-bottom: 4px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 500;
            color: var(--txt2);
            text-decoration: none;
            transition: background .15s, color .15s;
        }

            .nav-item:hover {
                background: var(--bg3);
                color: var(--txt);
            }

            .nav-item.active {
                background: var(--gold-lt);
                color: var(--gold);
                border: 1px solid rgba(201,168,76,.2);
            }

            .nav-item i {
                font-size: 15px;
                width: 18px;
                text-align: center;
            }

        .sidebar-foot {
            margin-top: auto;
            padding-top: 20px;
            border-top: 1px solid var(--line);
        }

        .settings-menu summary {
            list-style: none;
        }

            .settings-menu summary::-webkit-details-marker {
                display: none;
            }

        .settings-panel {
            margin-top: 6px;
        }

        /* MAIN */
        .main {
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* TOPBAR */
        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 14px 32px;
            border-bottom: 1px solid var(--line);
            background: var(--bg);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .topbar-search {
            position: relative;
            flex: 1;
            max-width: 360px;
        }

            .topbar-search i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--txt3);
                font-size: 13px;
                pointer-events: none;
            }

            .topbar-search input {
                width: 100%;
                height: 36px;
                background: var(--bg3);
                border: 1px solid var(--line2);
                border-radius: 9px;
                padding: 0 12px 0 34px;
                color: var(--txt);
                font-family: 'Inter', sans-serif;
                font-size: 13px;
                outline: none;
                transition: border-color .15s;
            }

                .topbar-search input::placeholder {
                    color: var(--txt3);
                }

                .topbar-search input:focus {
                    border-color: var(--gold);
                }

        .btn-ghost-sm {
            height: 36px;
            padding: 0 14px;
            background: var(--bg3);
            border: 1px solid var(--line2);
            border-radius: 9px;
            color: var(--txt2);
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            cursor: pointer;
            white-space: nowrap;
            transition: color .15s;
        }

            .btn-ghost-sm:hover {
                color: var(--txt);
            }

        .btn-clear-link {
            height: 36px;
            padding: 0 12px;
            display: inline-flex;
            align-items: center;
            background: var(--bg3);
            border: 1px solid var(--line2);
            border-radius: 9px;
            color: var(--txt3);
            font-size: 12px;
            text-decoration: none;
        }

        .btn-new {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--gold);
            color: #0d0d0d;
            border: none;
            border-radius: 9px;
            padding: 0 16px;
            height: 36px;
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: opacity .15s, transform .1s;
            white-space: nowrap;
        }

            .btn-new:hover {
                opacity: .88;
                transform: translateY(-1px);
                color: #0d0d0d;
            }

        /* CONTENT */
        .content {
            padding: 32px;
            flex: 1;
        }

        /* HERO */
        .hero {
            margin-bottom: 28px;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 8px;
        }

            .hero-eyebrow::before {
                content: '';
                display: block;
                width: 18px;
                height: 2px;
                background: var(--gold);
                border-radius: 2px;
            }

        .hero h1 {
            font-family: 'Syne', sans-serif;
            font-size: 36px;
            font-weight: 800;
            color: var(--txt);
            line-height: 1.1;
            letter-spacing: -.02em;
        }

            .hero h1 span {
                color: var(--gold);
            }

        /* STATS */
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
            margin-bottom: 28px;
        }

        .stat {
            background: var(--bg2);
            border: 1px solid var(--line);
            border-radius: var(--r-lg);
            padding: 20px 22px;
            position: relative;
            overflow: hidden;
            transition: border-color .2s;
        }

            .stat:hover {
                border-color: var(--line2);
            }

            .stat::after {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 100px;
                height: 100px;
                border-radius: 50%;
                pointer-events: none;
            }

            .stat.s-gold::after {
                background: var(--gold-glow);
                opacity: .5;
            }

            .stat.s-green::after {
                background: rgba(74,222,128,.15);
            }

            .stat.s-red::after {
                background: rgba(248,113,113,.15);
            }

        .stat-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .stat-tag {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--txt3);
        }

        .stat-ico {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

            .stat-ico.gold {
                background: var(--gold-lt);
                color: var(--gold);
            }

            .stat-ico.green {
                background: var(--green-lt);
                color: var(--green);
            }

            .stat-ico.red {
                background: var(--red-lt);
                color: var(--red);
            }

        .stat-num {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--txt);
            line-height: 1;
        }

        /* FILTERS */
        .filter-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .filter-lbl {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--txt3);
            margin-right: 4px;
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            height: 30px;
            padding: 0 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            text-decoration: none;
            border: 1px solid var(--line);
            cursor: pointer;
            transition: opacity .15s, transform .1s;
            white-space: nowrap;
            color: var(--txt2);
            background: var(--bg3);
        }

            .pill:hover {
                opacity: .8;
                transform: translateY(-1px);
                color: var(--txt);
            }

            .pill.red {
                background: var(--red-lt);
                color: var(--red);
                border-color: rgba(248,113,113,.25);
            }

            .pill.amber {
                background: var(--amber-lt);
                color: var(--amber);
                border-color: rgba(251,191,36,.25);
            }

            .pill.green {
                background: var(--green-lt);
                color: var(--green);
                border-color: rgba(74,222,128,.25);
            }

        .pdot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }

        /* TABLE CARD */
        .tcard {
            background: var(--bg2);
            border: 1px solid var(--line);
            border-radius: var(--r-lg);
            overflow: hidden;
        }

        .tcard-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid var(--line);
        }

        .tcard-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
            color: var(--txt);
        }

            .tcard-title i {
                color: var(--gold);
                font-size: 15px;
            }

        .count-chip {
            background: var(--bg4);
            color: var(--txt3);
            font-size: 11px;
            font-weight: 600;
            border-radius: 20px;
            padding: 3px 10px;
            border: 1px solid var(--line);
        }

        /* Table */
        .tbl {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .col-foto {
            width: 68px;
        }

        .col-nome {
            width: auto;
        }

        .col-qty {
            width: 100px;
        }

        .col-price {
            width: 120px;
        }

        .col-acts {
            width: 340px;
        }

        .tbl thead th {
            padding: 10px 16px;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--txt3);
            background: var(--bg3);
            border-bottom: 1px solid var(--line);
            text-align: left;
        }

            .tbl thead th.r {
                text-align: right;
            }

            .tbl thead th.c {
                text-align: center;
            }

        .tbl tbody td.r {
            text-align: center;
            
        }

            .tbl tbody tr:last-child {
                border-bottom: none;
            }

            .tbl tbody tr:hover {
                background: var(--bg3);
            }

        .tbl tbody td {
            vertical-align: middle;
        }

            .tbl tbody td.r {
                text-align: right;
            }

            .tbl tbody td.c {
                text-align: center;
            }

            .tbl tbody td.no-clip {
                text-align: center;
            }

        .thumb {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid var(--line2);
            display: block;
        }

        .prod-name {
            font-weight: 500;
            font-size: 14px;
            color: var(--txt);
        }

        .qty-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 6px;
        }

            .qty-badge.low {
                background: var(--red-lt);
                color: var(--red);
            }

            .qty-badge.medium {
                background: var(--amber-lt);
                color: var(--amber);
            }

            .qty-badge.high {
                background: var(--green-lt);
                color: var(--green);
            }

        .price-val {
            display: inline-block;
            min-width: 90px;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
        }

        .acts {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .btn-act {
            height: 28px;
            padding: 0 8px;
            font-size: 11px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-edit {
            background: var(--bg4);
            color: var(--txt2);
            border-color: var(--line2);
        }

            .btn-edit:hover {
                background: var(--bg3);
                color: var(--txt);
            }

        .btn-del {
            background: var(--red-lt);
            color: var(--red);
            border-color: rgba(248,113,113,.2);
        }

            .btn-del:hover {
                background: rgba(248,113,113,.18);
                color: var(--red);
            }

        .empty {
            padding: 60px 24px;
            text-align: center;
        }

        .empty-ico {
            font-size: 32px;
            color: var(--txt3);
            margin-bottom: 12px;
        }

        .empty p {
            font-size: 13px;
            color: var(--txt2);
            line-height: 1.7;
        }

        @@media (max-width: 900px) {
            .shell {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }

            .content {
                padding: 20px 16px;
            }
        }

        @@media (max-width: 600px) {
            .stats {
                grid-template-columns: 1fr;
            }

            .hero h1 {
                font-size: 26px;
            }
        }
    </style>
</head>
<body>

    <div class="shell">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestão</div>
                </div>
            </div>

            <nav style="display:flex; flex-direction:column; gap:4px;">
                <div class="nav-label">Principal</div>

                <a href="@Url.Action("Index", "Produto")" class="nav-item active">
                    <i class="bi bi-boxes"></i> Estoque
                </a>

                <a href="@Url.Action("Create", "Produto")" class="nav-item">
                    <i class="bi bi-plus-circle"></i> Novo Produto
                </a>

                @if (Session["EhAdminPrincipal"] != null && (bool)Session["EhAdminPrincipal"])
                {
                    <a href="@Url.Action("Index", "Usuarios")" class="nav-item">
                        <i class="bi bi-people"></i> Usuarios
                    </a>
                }

                <div class="nav-label" style="margin-top:12px;">Movimentações</div>

                <a href="@Url.Action("HistoricoEntrada", "Produto")" class="nav-item">
                    <i class="bi bi-arrow-down-circle"></i> Entradas
                </a>

                <a href="@Url.Action("HistoricoSaida", "Produto")" class="nav-item">
                    <i class="bi bi-arrow-up-circle"></i> Saídas
                </a>
            </nav>

            <div class="sidebar-foot">
                <details class="settings-menu">
                    <summary class="nav-item" style="font-size:12px; cursor:pointer;">
                        <i class="bi bi-gear"></i> Configurações
                    </summary>
                    <div class="settings-panel">
                        <a href="@Url.Action("Logout", "Admin")" class="nav-item" style="font-size:12px;">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </details>
            </div>
        </aside>

        <!-- MAIN -->
        <div class="main">

            <!-- TOPBAR -->
            <div class="topbar">
                <form method="get" action="@Url.Action("Index", "Produto")" style="flex:1; display:flex; gap:8px; align-items:center; max-width:440px;">
                    <div class="topbar-search" style="flex:1;">
                        <i class="bi bi-search"></i>
                        <input type="text" name="busca" placeholder="Buscar produto..." value="@ViewBag.BuscaAtual" />
                    </div>
                    <button type="submit" class="btn-ghost-sm">Buscar</button>
                    @if (ViewBag.BuscaAtual != null)
                    {
                        <a href="@Url.Action("Index", "Produto")" class="btn-clear-link">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </form>
                <a href="@Url.Action("Create", "Produto")" class="btn-new">
                    <i class="bi bi-plus-lg"></i> Novo Produto
                </a>
            </div>

            <!-- CONTENT -->
            <div class="content">

                <div class="hero">
                    <div class="hero-eyebrow">Controle de Estoque</div>
                    <h1>Produtos da <span>Marcenaria</span></h1>
                </div>

                <div class="stats">
                    <div class="stat s-gold">
                        <div class="stat-top">
                            <span class="stat-tag">Total de Produtos</span>
                            <div class="stat-ico gold"><i class="bi bi-box-seam"></i></div>
                        </div>
                        <div class="stat-num">@Model.Count()</div>
                    </div>
                    <div class="stat s-green">
                        <div class="stat-top">
                            <span class="stat-tag">Valor em Estoque</span>
                            <div class="stat-ico green"><i class="bi bi-wallet2"></i></div>
                        </div>
                        <div class="stat-num" style="font-size:22px;">R$&nbsp;@Model.Sum(p => p.Preco).ToString("N0")</div>
                    </div>
                    <div class="stat s-red">
                        <div class="stat-top">
                            <span class="stat-tag">Sem Preço</span>
                            <div class="stat-ico red"><i class="bi bi-exclamation-circle"></i></div>
                        </div>
                        <div class="stat-num">@Model.Count(p => p.Preco == 0)</div>
                    </div>
                </div>

                <div class="filter-bar">
                    <span class="filter-lbl">Filtrar por</span>
                    <a href="@Url.Action("Index", new { filtro = "baixo" })" class="pill red">  <span class="pdot"></span> Estoque Baixo</a>
                    <a href="@Url.Action("Index", new { filtro = "medio" })" class="pill amber"><span class="pdot"></span> Estoque Médio</a>
                    <a href="@Url.Action("Index", new { filtro = "alto" })" class="pill green"><span class="pdot"></span> Estoque Alto</a>
                    <a href="@Url.Action("Index")" class="pill">              <span class="pdot"></span> Todos</a>
                </div>

                <div class="tcard">
                    <div class="tcard-head">
                        <span class="tcard-title">
                            <i class="bi bi-table"></i> Produtos cadastrados
                        </span>
                        <span class="count-chip">@Model.Count() @(Model.Count() == 1 ? "item" : "itens")</span>
                    </div>

                    <div style="overflow-x:auto;">
                        <table class="tbl">
                            <colgroup>
                                <col class="col-foto" />
                                <col class="col-nome" />
                                <col class="col-qty" />
                                <col class="col-price" />
                                <col class="col-acts" />
                            </colgroup>
                            <thead>
                                <tr>
                                    <th>Foto</th>
                                    <th>Produto</th>
                                    <th class="c">Qtd.</th>
                                    <th class="r">Preço</th>
                                    <th class="r">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="5">
                                            <div class="empty">
                                                <div class="empty-ico"><i class="bi bi-inbox"></i></div>
                                                <p>Nenhum produto encontrado.<br />Clique em <strong>Novo Produto</strong> para começar.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var item in Model)
                                    {
                                        string qtyClass = "high";
                                        if (item.Quantidade < 50) { qtyClass = "low"; }
                                        else if (item.Quantidade <= 100) { qtyClass = "medium"; }

                                        <tr>
                                            <td>
                                                <img src="@Url.Content(item.ImagemUrl ?? "~/Content/images/default.jpeg")"
                                                     class="thumb" alt="@item.Nome" />
                                            </td>
                                            <td><span class="prod-name">@item.Nome</span></td>
                                            <td class="c"><span class="qty-badge @qtyClass">@item.Quantidade</span></td>
                                            <td class="r"><span class="price-val">R$ @item.Preco.ToString("N2")</span></td>
                                            <td class="r no-clip">
                                                <div class="acts">
                                                    <a href="@Url.Action("Edit",   "Produto", new { id = item.Id })" class="btn-act btn-edit"><i class="bi bi-pencil"></i> Editar</a>
                                                    <a href="@Url.Action("Delete", "Produto", new { id = item.Id })" class="btn-act btn-del"><i class="bi bi-trash3"></i> Excluir</a>
                                                    <a href="@Url.Action("Entrada", "Produto", new { id = item.Id })"
                                                       class="btn-act" style="background:rgba(74,222,128,.1); color:#4ade80;">
                                                        <i class="bi bi-plus-lg"></i> Entrada
                                                    </a>

                                                    <a href="@Url.Action("Saida", "Produto", new { id = item.Id })"
                                                       class="btn-act" style="background:rgba(248,113,113,.1); color:#f87171;">
                                                        <i class="bi bi-dash-lg"></i> Saída
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>
