@model IEnumerable<Estoque.Models.Movimentacao>
@{
    Layout = null;
}
<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <title>Histórico de Entradas</title>

    
    <style>
        body {
            background: #0d0d0d;
            color: white;
            font-family: Arial;
            padding: 40px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #141414;
        }

        th, td {
            padding: 12px;
            border-bottom: 1px solid #222;
            text-align: center;
        }

        th {
            color: #999;
            font-size: 12px;
        }

        .green {
            color: #4ade80;
            font-weight: bold;
        }

        .top-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
        }

        .btn-back {
            background: #1c1c1c;
            color: #9a9690;
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 8px;
            padding: 10px 14px;
            text-decoration: none;
            font-size: 13px;
            font-weight: bold;
        }

            .btn-back:hover {
                color: white;
            }
    </style>
   
</head>
<body>

    <div class="top-actions">
        <h2>Histórico de Entradas</h2>
        <a href="@Url.Action("Index", "Produto")" class="btn-back">Voltar ao estoque</a>
    </div>

    <table>
        <tr>
            <th>Produto</th>
            <th>Quantidade</th>
            <th>Data</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NomeProduto</td>
                <td class="green">+@item.Quantidade</td>
                <td>@item.Data</td>
            </tr>
        }
        

    </table>

</body>
</html>
