@model Estoque.Models.Produto

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Saida de Estoque</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { margin: 0; background: #0d0d0d; color: #f0ede8; font-family: 'Inter', sans-serif; }
        .container { display: flex; justify-content: center; align-items: center; height: 100vh; }
        .card { background: #141414; border: 1px solid rgba(255,255,255,.07); border-radius: 16px; width: 100%; max-width: 420px; padding: 24px; }
        h1 { font-size: 22px; margin-bottom: 10px; }
        .subtitle { font-size: 12px; color: #9a9690; margin-bottom: 20px; }
        .produto { font-size: 16px; font-weight: 600; margin-bottom: 10px; }
        .badge { display: inline-block; padding: 6px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; margin-bottom: 15px; }
        .low { background: rgba(248,113,113,.1); color: #f87171; }
        .medium { background: rgba(251,191,36,.1); color: #fbbf24; }
        .high { background: rgba(74,222,128,.1); color: #4ade80; }
        input { width: 100%; height: 40px; background: #1c1c1c; border: 1px solid rgba(255,255,255,.1); border-radius: 8px; padding: 0 10px; color: white; margin-bottom: 15px; }
        .actions { display: flex; gap: 10px; }
        .btn { flex: 1; height: 38px; border: none; border-radius: 8px; cursor: pointer; font-size: 13px; font-weight: 600; display: flex; align-items: center; justify-content: center; text-decoration: none; }
        .btn-danger { background: rgba(248,113,113,.1); color: #f87171; }
        .btn-secondary { background: #1c1c1c; color: #9a9690; }
        .btn:hover { opacity: 0.85; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h1><i class="bi bi-dash-circle"></i> Saida de Estoque</h1>
            <div class="subtitle">Remover itens do estoque</div>
            <div class="produto">@Model.Nome</div>
            <div class="badge @(Model.Quantidade < 50 ? "low" : Model.Quantidade <= 100 ? "medium" : "high")">
                Atual: @Model.Quantidade
            </div>

            @using (Html.BeginForm())
            {
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="number" name="quantidade" placeholder="Quantidade a retirar" required />

                <div class="actions">
                    <button type="submit" class="btn btn-danger">Confirmar</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
                </div>
            }
        </div>
    </div>
</body>
</html>
