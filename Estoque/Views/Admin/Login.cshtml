@{
    ViewBag.Title = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d0d0d;
            --bg2: #141414;
            --bg3: #1c1c1c;
            --bg4: #242424;
            --line: rgba(255,255,255,.07);
            --line2: rgba(255,255,255,.12);
            --txt: #f0ede8;
            --txt2: #9a9690;
            --txt3: #5c5a57;
            --gold: #c9a84c;
            --gold-lt: rgba(201,168,76,.12);
            --gold-md: rgba(201,168,76,.22);
            --red: #f87171;
            --red-lt: rgba(248,113,113,.1);
            --red-bd: rgba(248,113,113,.25);
            --r: 10px;
            --r-lg: 16px;
        }

        html, body {
            min-height: 100vh;
            background: var(--bg);
            color: var(--txt);
            font-family: 'Inter', system-ui, sans-serif;
            font-size: 14px;
            line-height: 1.5;
        }

        /* ── LAYOUT ─────────────────────────────── */
        .split {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 480px;
        }

        /* ── LEFT PANEL ─────────────────────────── */
        .panel-left {
            background: var(--bg2);
            border-right: 1px solid var(--line);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 64px;
            position: relative;
            overflow: hidden;
        }

            /* subtle grid lines */
            .panel-left::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(var(--line) 1px, transparent 1px), linear-gradient(90deg, var(--line) 1px, transparent 1px);
                background-size: 48px 48px;
                pointer-events: none;
            }

            /* gold glow blob */
            .panel-left::after {
                content: '';
                position: absolute;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(201,168,76,.12) 0%, transparent 65%);
                bottom: -100px;
                right: -100px;
                pointer-events: none;
            }

        .brand-lockup {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 56px;
            position: relative;
            z-index: 1;
        }

        .brand-icon {
            width: 38px;
            height: 38px;
            background: var(--gold);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0d0d0d;
            font-size: 16px;
            flex-shrink: 0;
        }

        .brand-name {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--txt);
        }

        .brand-sub {
            font-size: 10px;
            color: var(--txt3);
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .left-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

            .left-eyebrow::before {
                content: '';
                display: block;
                width: 18px;
                height: 2px;
                background: var(--gold);
                border-radius: 2px;
            }

        .left-heading {
            font-family: 'Syne', sans-serif;
            font-size: clamp(28px, 3vw, 44px);
            font-weight: 800;
            color: var(--txt);
            line-height: 1.1;
            letter-spacing: -.025em;
            margin-bottom: 20px;
            position: relative;
            z-index: 1;
        }

            .left-heading span {
                color: var(--gold);
            }

        .left-desc {
            font-size: 14px;
            color: var(--txt2);
            line-height: 1.75;
            max-width: 380px;
            margin-bottom: 48px;
            position: relative;
            z-index: 1;
        }

        /* Feature list */
        .features {
            display: flex;
            flex-direction: column;
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .feature {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .feature-dot {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: var(--gold-lt);
            border: 1px solid rgba(201,168,76,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gold);
            font-size: 13px;
            flex-shrink: 0;
        }

        .feature-txt {
            font-size: 13px;
            font-weight: 500;
            color: var(--txt2);
        }

        /* bottom bar */
        .left-foot {
            position: absolute;
            bottom: 32px;
            left: 64px;
            display: flex;
            gap: 32px;
            z-index: 1;
        }

        .left-stat-num {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--gold);
            line-height: 1;
            margin-bottom: 3px;
        }

        .left-stat-lbl {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--txt3);
        }

        /* ── RIGHT PANEL ────────────────────────── */
        .panel-right {
            background: var(--bg);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 48px 40px;
            border-left: 1px solid var(--line);
        }

        .form-box {
            width: 100%;
            max-width: 360px;
        }

        /* Form header */
        .form-header {
            margin-bottom: 36px;
        }

            .form-header .eyebrow {
                font-size: 11px;
                font-weight: 600;
                letter-spacing: .1em;
                text-transform: uppercase;
                color: var(--txt3);
                margin-bottom: 8px;
            }

            .form-header h2 {
                font-family: 'Syne', sans-serif;
                font-size: 24px;
                font-weight: 800;
                color: var(--txt);
                letter-spacing: -.02em;
                line-height: 1.2;
            }

            .form-header p {
                font-size: 13px;
                color: var(--txt2);
                margin-top: 6px;
            }

        /* Error banner */
        .error-banner {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--red-lt);
            border: 1px solid var(--red-bd);
            border-radius: var(--r);
            padding: 12px 14px;
            margin-bottom: 24px;
            font-size: 13px;
            color: var(--red);
        }

            .error-banner i {
                font-size: 14px;
                flex-shrink: 0;
            }

        /* Field */
        .field {
            margin-bottom: 16px;
        }

            .field label {
                display: block;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .08em;
                color: var(--txt3);
                margin-bottom: 7px;
            }

        .field-wrap {
            position: relative;
        }

            .field-wrap i.ico {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--txt3);
                font-size: 13px;
                pointer-events: none;
                z-index: 2;
            }

            .field-wrap input {
                width: 100%;
                height: 44px;
                background: var(--bg3);
                border: 1px solid var(--line2);
                border-radius: var(--r);
                padding: 0 14px 0 38px;
                color: var(--txt);
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                outline: none;
                transition: border-color .15s, box-shadow .15s;
            }

                .field-wrap input::placeholder {
                    color: var(--txt3);
                }

                .field-wrap input:focus {
                    border-color: var(--gold);
                    box-shadow: 0 0 0 3px rgba(201,168,76,.12);
                }

        .toggle-pw {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: var(--txt3);
            font-size: 14px;
            cursor: pointer;
            padding: 0;
            z-index: 2;
            transition: color .15s;
        }

            .toggle-pw:hover {
                color: var(--gold);
            }

        /* Remember row */
        .row-remember {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            margin-top: 4px;
        }

        .check-label {
            display: flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            font-size: 12px;
            color: var(--txt2);
        }

            .check-label input[type=checkbox] {
                width: 14px;
                height: 14px;
                accent-color: var(--gold);
                cursor: pointer;
            }

        .link-forgot {
            font-size: 12px;
            font-weight: 500;
            color: var(--gold);
            text-decoration: none;
            transition: opacity .15s;
        }

            .link-forgot:hover {
                opacity: .75;
            }

        /* Submit */
        .btn-login {
            width: 100%;
            height: 46px;
            background: var(--gold);
            border: none;
            border-radius: var(--r);
            color: #0d0d0d;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: .02em;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity .15s, transform .1s;
            margin-bottom: 28px;
        }

            .btn-login:hover {
                opacity: .88;
                transform: translateY(-1px);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        /* Divider */
        .form-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }

            .form-divider hr {
                flex: 1;
                border: none;
                border-top: 1px solid var(--line);
            }

            .form-divider span {
                font-size: 11px;
                color: var(--txt3);
                letter-spacing: .06em;
                text-transform: uppercase;
                white-space: nowrap;
            }

        /* Footer */
        .form-foot {
            text-align: center;
            font-size: 12px;
            color: var(--txt3);
            padding-top: 24px;
            border-top: 1px solid var(--line);
        }

            .form-foot strong {
                color: var(--txt2);
            }

        @@media (max-width: 820px) {
            .split {
                grid-template-columns: 1fr;
            }

            .panel-left {
                display: none;
            }

            .panel-right {
                padding: 40px 24px;
            }
        }
    </style>
</head>
<body>

    <div class="split">

        <!-- LEFT -->
        <div class="panel-left">

            <div class="brand-lockup">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <div class="brand-name">Marcenaria</div>
                    <div class="brand-sub">Sistema de Gestão</div>
                </div>
            </div>

            <div class="left-eyebrow">Plataforma de Estoque</div>

            <h2 class="left-heading">
                Gestão inteligente<br>do seu <span>ateliê</span>.
            </h2>

            <p class="left-desc">
                Controle total sobre materiais, ferramentas e projetos.
                Tudo que sua marcenaria precisa em um único painel.
            </p>

            <div class="features">
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-boxes"></i></div>
                    <span class="feature-txt">Controle de estoque em tempo real</span>
                </div>
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-graph-up"></i></div>
                    <span class="feature-txt">Relatórios e dashboards</span>
                </div>
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-tools"></i></div>
                    <span class="feature-txt">Gestão de ferramentas e insumos</span>
                </div>
                <div class="feature">
                    <div class="feature-dot"><i class="bi bi-shield-check"></i></div>
                    <span class="feature-txt">Acesso seguro por usuário</span>
                </div>
            </div>

            <div class="left-foot">
                <div>
                    <div class="left-stat-num">+800</div>
                    <div class="left-stat-lbl">Itens gerenciados</div>
                </div>
                <div>
                    <div class="left-stat-num">99%</div>
                    <div class="left-stat-lbl">Disponibilidade</div>
                </div>
                <div>
                    <div class="left-stat-num">24/7</div>
                    <div class="left-stat-lbl">Acesso online</div>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="panel-right">
            <div class="form-box">

                <div class="form-header">
                    <div class="eyebrow">Acesso ao sistema</div>
                    <h2>Bem-vindo de volta</h2>
                    <p>Acesse o painel de gestão da marcenaria</p>
                </div>

                @if (ViewBag.Erro != null)
                {
                    <div class="error-banner">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @ViewBag.Erro
                    </div>
                }

                <form method="post">

                    <div class="field">
                        <label>Usuário</label>
                        <div class="field-wrap">
                            <i class="bi bi-person-fill ico"></i>
                            <input type="text" name="usuario" placeholder="Digite seu usuário"
                                   autocomplete="username" required />
                        </div>
                    </div>

                    <div class="field">
                        <label>Senha</label>
                        <div class="field-wrap">
                            <i class="bi bi-lock-fill ico"></i>
                            <input type="password" name="senha" id="senhaInput"
                                   placeholder="Digite sua senha"
                                   autocomplete="current-password" required />
                            <button type="button" class="toggle-pw" onclick="toggleSenha()">
                                <i class="bi bi-eye-fill" id="eyeIcon"></i>
                            </button>
                        </div>
                    </div>

                    <div class="row-remember">
                        <label class="check-label">
                            <input type="checkbox" name="lembrar" />
                            Lembrar-me
                        </label>
                        <a href="#" class="link-forgot">Esqueci a senha</a>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Entrar no sistema
                    </button>

                </form>

                <div class="form-divider">
                    <hr /><span>Estoque Marcenaria</span><hr />
                </div>

                <div class="form-foot">
                    <strong>Estoque Marcenaria</strong> &copy; @DateTime.Now.Year &mdash; v2.0
                </div>

            </div>
        </div>

    </div>

    <script>
        function toggleSenha() {
            var input = document.getElementById('senhaInput');
            var icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash-fill';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye-fill';
            }
        }
    </script>

</body>
</html>
