@model Estoque.Models.ViewModels.CadastroUsuarioViewModel

@{
    ViewBag.Title = "Cadastro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro - Marcenaria</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #0d0d0d;
            --bg2: #141414;
            --bg3: #1c1c1c;
            --line: rgba(255,255,255,.1);
            --txt: #f0ede8;
            --txt2: #9a9690;
            --txt3: #5c5a57;
            --gold: #c9a84c;
            --red: #f87171;
            --green: #4ade80;
        }

        body {
            min-height: 100vh;
            background: var(--bg);
            color: var(--txt);
            font-family: 'Inter', sans-serif;
        }

        .split {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 460px;
        }

        .panel-left {
            background: var(--bg2);
            border-right: 1px solid var(--line);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 64px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 50px;
        }

        .brand-icon {
            width: 38px;
            height: 38px;
            background: var(--gold);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0d0d0d;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-size: 40px;
            line-height: 1.1;
            max-width: 500px;
        }

        h1 span {
            color: var(--gold);
        }

        .panel-left p {
            color: var(--txt2);
            line-height: 1.8;
            max-width: 420px;
            margin-top: 18px;
        }

        .panel-right {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 42px;
        }

        .box {
            width: 100%;
            max-width: 360px;
        }

        .eyebrow {
            color: var(--txt3);
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        h2 {
            font-family: 'Syne', sans-serif;
            margin-bottom: 8px;
        }

        .hint {
            color: var(--txt2);
            font-size: 13px;
            margin-bottom: 26px;
        }

        .field {
            margin-bottom: 16px;
        }

        label {
            display: block;
            color: var(--txt3);
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .08em;
            text-transform: uppercase;
            margin-bottom: 7px;
        }

        input {
            width: 100%;
            height: 44px;
            background: var(--bg3);
            border: 1px solid var(--line);
            border-radius: 10px;
            color: var(--txt);
            padding: 0 14px;
            font-family: 'Inter', sans-serif;
            outline: none;
        }

        input:focus {
            border-color: var(--gold);
        }

        .msg {
            border-radius: 10px;
            padding: 12px 14px;
            margin-bottom: 18px;
            font-size: 13px;
        }

        .msg.error {
            color: var(--red);
            background: rgba(248,113,113,.1);
            border: 1px solid rgba(248,113,113,.25);
        }

        .msg.success {
            color: var(--green);
            background: rgba(74,222,128,.1);
            border: 1px solid rgba(74,222,128,.25);
        }

        .val-error {
            display: block;
            color: var(--red);
            font-size: 12px;
            margin-top: 6px;
        }

        .btn {
            width: 100%;
            height: 46px;
            border: none;
            border-radius: 10px;
            background: var(--gold);
            color: #0d0d0d;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
        }

        .back {
            display: block;
            text-align: center;
            margin-top: 22px;
            color: var(--gold);
            text-decoration: none;
            font-size: 13px;
        }

        @@media (max-width: 820px) {
            .split {
                grid-template-columns: 1fr;
            }

            .panel-left {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="split">
        <div class="panel-left">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-tools"></i></div>
                <div>
                    <strong>Marcenaria</strong><br />
                    <small style="color:var(--txt3);">Sistema de Gestao</small>
                </div>
            </div>

            <h1>Solicite seu acesso ao <span>sistema</span>.</h1>
            <p>Depois do cadastro, aguarde a liberacao do administrador para entrar no painel da marcenaria.</p>
        </div>

        <div class="panel-right">
            <div class="box">
                <div class="eyebrow">Novo usuario</div>
                <h2>Criar acesso</h2>
                <p class="hint">Preencha os dados para solicitar entrada no sistema.</p>

                @if (ViewBag.Erro != null)
                {
                    <div class="msg error">@ViewBag.Erro</div>
                }

                @if (ViewBag.Sucesso != null)
                {
                    <div class="msg success">@ViewBag.Sucesso</div>
                }

                @Html.ValidationSummary(true, "", new { @class = "msg error" })

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="field">
                        <label>Nome</label>
                        @Html.TextBoxFor(m => m.Nome, new { required = "required" })
                        @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "val-error" })
                    </div>

                    <div class="field">
                        <label>E-mail</label>
                        @Html.TextBoxFor(m => m.Email, new { type = "email", required = "required" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "val-error" })
                    </div>

                    <div class="field">
                        <label>Senha</label>
                        @Html.PasswordFor(m => m.Senha, new { required = "required" })
                        @Html.ValidationMessageFor(m => m.Senha, "", new { @class = "val-error" })
                    </div>

                    <button class="btn" type="submit">Cadastrar usuario</button>
                </form>

                <a class="back" href="@Url.Action("Login", "Admin")">Voltar para o login</a>
            </div>
        </div>
    </div>
</body>
</html>
